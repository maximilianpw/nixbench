---
import SiteLayout from "@/layouts/SiteLayout.astro";
import {
  FailureSection,
  ResultsHero,
  ResultsSummary,
  TaskResultsSection,
  TimingChart,
} from "@/components/sections/ResultsSections";
---

<SiteLayout
  title="NixBench Results | GPT Model Comparison"
  description="NixBench results for GPT-5.5, GPT-5.4, GPT-5.4 mini, and a partial Claude Opus 4.8 run on the 24-task corpus."
  activePage="results"
  canonicalPath="/results.html"
  footer={{
    text: "Raw run artifacts are local under <code>results/</code>; durable comparison notes are tracked under <code>docs/runs/</code>.",
    href: "index.html",
    label: "Back to benchmark landing page",
  }}
>
  <main>
    <ResultsHero />
    <ResultsSummary />
    <TaskResultsSection />
    <section class="section timing-section" aria-labelledby="timing-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Agent duration</p>
          <h2 id="timing-heading">Full GPT runs took about 37 minutes each.</h2>
        </div>
      </div>
      <TimingChart client:visible />
    </section>
    <FailureSection />
  </main>
</SiteLayout>
