---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { ResultsPage } from "@/components/pages/ResultsPage";
---

<SiteLayout
  title="NixBench Results | GPT Model Comparison"
  description="NixBench results for GPT-5.5, GPT-5.4, GPT-5.4 mini, and Claude Opus 4.8 on the 26-task corpus."
  activePage="results"
  canonicalPath="/results.html"
  footer={{
    text: "Raw run artifacts are local under <code>results/</code>; durable comparison notes are tracked under <code>docs/runs/</code>.",
    href: "index.html",
    label: "Back to benchmark landing page",
  }}
>
  <ResultsPage client:load />
</SiteLayout>
